PORT=8787
CODEX_COMMAND=codex
CODEX_TIMEOUT_MS=180000
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=local_master_key
MEILI_INDEX=knowledge_notes
KNOWLEDGE_READ_ONLY=0
REDIS_HOST=localhost
REDIS_PORT=6379

# Auth — defaults to single-user local mode (userId="local", no login).
# Set AUTH_SECRET to require `Authorization: Bearer <secret>` on API calls
# (for self-hosted instances exposed to the internet; note the web UI does not
# prompt for it — put the UI behind a reverse proxy or VPN instead).
#AUTH_SECRET=change-me
# AUTH_PROVIDER=supabase requires the extensions extensions/ modules (private repo).
#AUTH_PROVIDER=local

# Supabase — extensions builds only (knowledge-loom-private)
#SUPABASE_URL=https://your-project.supabase.co
#SUPABASE_ANON_KEY=your-anon-key
#SUPABASE_JWT_SECRET=your-jwt-secret
#VITE_SUPABASE_URL=https://your-project.supabase.co
#VITE_SUPABASE_ANON_KEY=your-anon-key

# Stripe — extensions builds only (real payments; unset = mock checkout)
#STRIPE_SECRET_KEY=sk_test_...
#STRIPE_WEBHOOK_SECRET=whsec_...   # from: stripe listen --forward-to localhost:8787/api/billing/webhook
#ADMIN_TOKEN=staff-dev-token       # enables the staff console API
