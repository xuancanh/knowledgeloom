{
  "name": "smart-knowledge-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "server": "node server/dist/main.js",
    "server:build": "rm -rf server/dist && tsc -p server/tsconfig.json",
    "server:dev": "ts-node --project server/tsconfig.json server/src/main.ts",
    "build": "npm run server:build && tsc -b && vite build && node scripts/check-bundle-size.mjs",
    "lint": "eslint .",
    "test": "npx tsx --test tests/backend-storage.test.ts tests/backend-note-parser.test.ts tests/backend-guards.test.ts tests/backend-reminders.test.ts tests/backend-services.test.ts tests/backend-fsrs.test.ts tests/backend-exam-plan.test.ts tests/backend-feature-toggles.test.ts tests/backend-learn-progress.test.ts tests/backend-restore.test.ts tests/backend-share-password.test.ts tests/backend-share-payload.test.ts tests/backend-spaces.test.ts",
    "test:frontend": "npx tsx --test tests/frontend-lib.test.ts tests/frontend-learn.test.ts tests/frontend-i18n.test.ts",
    "test:ui": "TSX_TSCONFIG_PATH=tsconfig.app.json NODE_OPTIONS='--import=./tests/register-css-loader.mjs' npx tsx --test tests/frontend-ui.test.tsx tests/frontend-share-ui.test.tsx",
    "test:all": "npm test && npm run test:frontend && npm run test:ui && npm run test:e2e && node --test --test-concurrency=1 --test-force-exit tests/integration-ai.test.mjs tests/integration-modes.test.mjs tests/integration-mcp.test.mjs",
    "smoke:meili": "npx tsx scripts/smoke-meili-sync.ts",
    "benchmark:vault": "npm run server:build && node scripts/benchmark-vault.mjs",
    "preview": "vite preview",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate-local": "node scripts/migrate-local-user.mjs",
    "test:e2e": "npm run server:build && node --test --test-force-exit tests/e2e-api.test.mjs tests/e2e-readonly.test.mjs",
    "test:e2e:postgres": "npm run server:build && DATABASE_DIALECT=postgres node --test --test-force-exit tests/e2e-api.test.mjs",
    "test:integration": "npm run server:build && node --test --test-concurrency=1 --test-force-exit tests/integration-ai.test.mjs tests/integration-modes.test.mjs tests/integration-mcp.test.mjs",
    "mcp": "node mcp/knowledge-loom-mcp.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/platform-express": "^11.1.27",
    "@supabase/supabase-js": "^2.106.1",
    "@tiptap/core": "^3.23.6",
    "@tiptap/extension-image": "^3.23.6",
    "@tiptap/extension-placeholder": "^3.23.6",
    "@tiptap/extension-table": "^3.23.6",
    "@tiptap/markdown": "^3.23.6",
    "@tiptap/react": "^3.23.6",
    "@tiptap/starter-kit": "^3.23.6",
    "@vitejs/plugin-react": "^6.0.1",
    "better-sqlite3": "^12.10.0",
    "bullmq": "^5.77.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "i18next": "^26.2.0",
    "ioredis": "^5.9.0",
    "jsonwebtoken": "^9.0.3",
    "mermaid": "^11.15.0",
    "pdf-parse": "^1.1.1",
    "pg": "^8.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "stripe": "^22.3.0",
    "typescript": "~6.0.2",
    "vite": "^8.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^24.12.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "global-jsdom": "^29.0.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript-eslint": "^8.59.2"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    },
    "multer": "^2.2.0",
    "dompurify": "^3.4.11",
    "lodash": "^4.17.24"
  },
  "license": "AGPL-3.0-or-later"
}
