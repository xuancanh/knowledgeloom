node_modules
dist
.env
.DS_Store

# Runtime knowledge data — managed by the app, not source-controlled
knowledge/*.sqlite
knowledge/*.sqlite-shm
knowledge/*.sqlite-wal
knowledge/index.json
knowledge/jobs.json
knowledge/flashcards.json
knowledge/meili-sync*.json
knowledge/notes/*
knowledge/categories/*
knowledge/users/

# Keep placeholder files
!knowledge/notes/.gitkeep
!knowledge/categories/.gitkeep

# Optional extension modules — linked (symlink) or merged from a private repo,
# never committed to the public tree. No trailing slash so the dev symlink is
# ignored too, not just a merged directory.
src/extensions
server/src/extensions

# Agent/session state and internal design sources — never in the public tree
.omo/
design/

# Docker Compose bind-mount data folder (notes, sqlite, redis, search index)
/data/
