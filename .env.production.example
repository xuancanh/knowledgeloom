# Knowledge Loom — production environment (Cloudflare + Supabase reference).
# Copy to your secret store (Cloudflare secrets / GitHub environments); never commit.

# ── core ──────────────────────────────────────────────────────────────────────
PORT=8787
# Lock CORS to your web origin(s) for a split frontend/API deployment.
# When unset, production accepts same-origin browser requests only.
CORS_ORIGIN=https://app.example.com
# Per-IP req/min ceiling on unauthenticated endpoints (share links, marketplace).
# Production uses atomic Redis counters so this allowance is shared by replicas.
PUBLIC_RATE_LIMIT_STORE=redis
PUBLIC_RATE_LIMIT=120
# Set a distinct prefix when multiple environments share one Redis database.
PUBLIC_RATE_LIMIT_PREFIX=knowledge-loom:production:rate-limit:
# Password attempts per protected share, per IP, per minute.
SHARE_UNLOCK_RATE_LIMIT=10
# All local-mode data derives from here (irrelevant once storage/db are cloud).
KNOWLEDGE_ROOT=/data

# ── auth: Supabase (requires the extensions tree at server/src/extensions) ───
AUTH_PROVIDER=supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_JWT_SECRET=...            # Supabase dashboard → API → JWT secret
SUPABASE_ANON_KEY=...              # used by the frontend build

# ── database: Supabase Postgres ───────────────────────────────────────────────
DATABASE_DIALECT=postgres
# Use the session pooler URL (port 5432/6543) from Supabase → Database → Connect.
DATABASE_URL=postgresql://postgres.YOUR-PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# ── note storage: Cloudflare R2 (S3-compatible) ───────────────────────────────
NOTE_STORAGE=s3
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_BUCKET=knowledge-loom-notes
S3_REGION=auto
S3_ACCESS_KEY_ID=...               # R2 API token (Object Read & Write)
S3_SECRET_ACCESS_KEY=...

# ── jobs queue: managed Redis (BullMQ needs the real Redis protocol) ──────────
# Upstash (TCP endpoint, not the REST API), Railway, or self-managed all work.
REDIS_HOST=...
REDIS_PORT=6379
REDIS_PASSWORD=...
# SKIP_JOBS=1                      # fallback: boot without the queue (AI capture disabled)

# ── search ────────────────────────────────────────────────────────────────────
SEARCH_PROVIDER=inmemory           # or meilisearch + MEILI_HOST/MEILI_MASTER_KEY

# ── AI provider (HTTP; the codex CLI is for local use) ────────────────────────
AI_PROVIDER=openrouter
AI_API_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=...
AI_MODEL=anthropic/claude-sonnet-5

# Optional feature keys (each falls back to a clean 501 when unset):
TRANSCRIBE_API_KEY=...             # audio/video import (Whisper-compatible)
VISION_API_KEY=...                 # image/handwriting import
TTS_API_KEY=...                    # podcast audio

# ── billing + admin (extensions) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
ADMIN_TOKEN=...                    # backoffice bearer token — long and random
